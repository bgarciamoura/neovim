{
  "Function": {
    "prefix": "fn",
    "body": ["function ${1:name}(${2:params})", "\t$0", "end"]
  },
  "Local function": {
    "prefix": "lfn",
    "body": ["local function ${1:name}(${2:params})", "\t$0", "end"]
  },
  "Require": {
    "prefix": "req",
    "body": "local ${1:mod} = require('${2:module}')"
  },
  "If": {
    "prefix": "if",
    "body": ["if ${1:cond} then", "\t$0", "end"]
  }
}
