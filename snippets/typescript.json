{
  "Function": {
    "prefix": "fn",
    "body": ["function ${1:name}(${2:params}): ${3:void} {", "\t$0", "}"]
  },
  "Arrow function": {
    "prefix": "afn",
    "body": ["const ${1:name} = (${2:params})${3: => {", "\t$0", "\\}}"]
  },
  "Import": {
    "prefix": "imp",
    "body": "import { $1 } from '${2:module}'$0"
  },
  "Import type": {
    "prefix": "impt",
    "body": "import type { $1 } from '${2:module}'$0"
  },
  "useState": {
    "prefix": "us",
    "body": "const [${1:state}, set${2:State}] = useState($3)$0"
  },
  "useEffect": {
    "prefix": "ue",
    "body": ["useEffect(() => {", "\t$0", "}, [${1:deps}])"]
  },
  "Console log": {
    "prefix": "cl",
    "body": "console.log($0)"
  },
  "Try catch": {
    "prefix": "trycatch",
    "body": ["try {", "\t$1", "} catch (${2:error}) {", "\t$0", "}"]
  }
}
